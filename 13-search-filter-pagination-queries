// Controller: Get all files with search, filter, sort and pagination

const getAllFiles = async (req, res) => {
  try {
    // Step 1: Read query params from URL
    const page = Number(req.query.page) || 1;
    const limit = Number(req.query.limit) || 5;

    // Step 2: Calculate how many documents to skip
    const skip = (page - 1) * limit;

    // Step 3: Read optional filters
    const search = req.query.search || "";
    const type = req.query.type || "";
    const sort = req.query.sort || "latest";

    // Step 4: Base query
    // Only show files of logged-in user
    const query = {
      user: req.user.id
    };

    // Step 5: Search by filename
    if (search) {
      query.filename = {
        $regex: search,
        $options: "i"
      };
    }

    // Step 6: Filter by file extension/type
    // Example:
    // type=image -> .jpg, .png, .jpeg
    // type=pdf -> .pdf
    if (type) {
      if (type === "image") {
        query.filename = {
          ...query.filename,
          $regex: "\\.(jpg|jpeg|png|gif|webp)$",
          $options: "i"
        };
      }

      if (type === "pdf") {
        query.filename = {
          ...query.filename,
          $regex: "\\.pdf$",
          $options: "i"
        };
      }
    }

    // Step 7: Sorting
    let sortOption = {};

    if (sort === "latest") {
      sortOption = { createdAt: -1 };
    }

    if (sort === "oldest") {
      sortOption = { createdAt: 1 };
    }

    if (sort === "name-asc") {
      sortOption = { filename: 1 };
    }

    if (sort === "name-desc") {
      sortOption = { filename: -1 };
    }

    // Step 8: Get filtered files from database
    const files = await File.find(query)
      .sort(sortOption)
      .skip(skip)
      .limit(limit);

    // Step 9: Count total files after filters
    const totalFiles = await File.countDocuments(query);

    // Step 10: Send response
    res.status(200).json({
      message: "Files fetched successfully",
      currentPage: page,
      totalPages: Math.ceil(totalFiles / limit),
      totalFiles,
      files
    });

  } catch (error) {
    res.status(500).json({
      message: error.message
    });
  }
};

